{
  "id": "/",
  "name": "Balcony Music Club",
  "short_name": "BMC",
  "description": "QR-ready guest app for Balcony Music Club.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui", "browser"],
  "orientation": "portrait",
  "background_color": "#120728",
